{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cloudsweep.local/schemas/finops-rule-v2.schema.json",
  "title": "CloudSweep FinOps Rule v2",
  "type": "object",
  "required": ["schema_version", "rule_id", "domain", "version", "facts", "predicate", "outcome", "handlers"],
  "properties": {
    "schema_version": {"const": "2.0"},
    "rule_id": {"type": "string", "minLength": 1},
    "domain": {"type": "string", "minLength": 1},
    "version": {"type": "string", "minLength": 1},
    "description": {"type": "string"},
    "facts": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["type"],
        "properties": {
          "type": {"enum": ["number", "integer", "string", "boolean", "array", "object"]},
          "required": {"type": "boolean"}
        },
        "additionalProperties": false
      }
    },
    "thresholds": {"type": "object"},
    "predicate": {"$ref": "#/$defs/predicate"},
    "outcome": {
      "type": "object",
      "required": ["severity", "action", "confidence"],
      "properties": {
        "severity": {"enum": ["HIGH", "MEDIUM", "LOW", "INFO"]},
        "action": {"type": "string", "minLength": 1},
        "confidence": {"enum": ["HIGH", "MEDIUM", "LOW"]}
      },
      "additionalProperties": true
    },
    "handlers": {
      "type": "object",
      "required": ["extractor", "savings", "remediation"],
      "properties": {
        "extractor": {"type": "string", "minLength": 1},
        "savings": {"type": "string", "minLength": 1},
        "remediation": {"type": "string", "minLength": 1}
      },
      "additionalProperties": false
    },
    "safety_checks": {"type": "array", "items": {"type": "string"}},
    "doc_query": {"type": "string"}
  },
  "additionalProperties": true,
  "$defs": {
    "predicate": {
      "oneOf": [
        {
          "type": "object",
          "required": ["all"],
          "properties": {"all": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/predicate"}}},
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["any"],
          "properties": {"any": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/predicate"}}},
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["not"],
          "properties": {"not": {"$ref": "#/$defs/predicate"}},
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["fact", "op"],
          "properties": {
            "fact": {"type": "string", "minLength": 1},
            "op": {"enum": ["eq", "ne", "gt", "gte", "lt", "lte", "in", "exists"]},
            "value": {},
            "threshold": {"type": "string"}
          },
          "oneOf": [{"required": ["value"]}, {"required": ["threshold"]}, {"properties": {"op": {"const": "exists"}}}],
          "additionalProperties": false
        }
      ]
    }
  }
}
